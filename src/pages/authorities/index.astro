---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const authorities = await getCollection('authorities');

const grouped = authorities.reduce((acc, authority) => {
  const type = authority.data.authority_type;
  if (!acc[type]) acc[type] = [];
  acc[type].push(authority);
  return acc;
}, {} as Record<string, typeof authorities>);

const typeOrder = [
  'federal regulator',
  'accrediting body',
  'state regulator',
  'recognized authority'
];

const typeLabels: Record<string, string> = {
  'federal regulator': 'Federal Regulators',
  'accrediting body': 'Accrediting Bodies',
  'state regulator': 'State Regulators',
  'recognized authority': 'Recognized Authorities'
};

const totalCount = authorities.length;
---

<BaseLayout
  title="Authority Index"
  description="Complete index of regulatory authorities covered by the Healthcare Pest Reference, organized by authority type."
>
  <style>
    .authority-list {
      list-style: none;
      margin: 0 0 2rem;
      padding: 0;
    }

    .authority-list li {
      padding: 1rem 0;
      border-bottom: 1px solid var(--color-rule);
    }

    .authority-list li:last-child {
      border-bottom: none;
    }

    .authority-list a {
      font-family: var(--font-serif);
      font-size: 1.1rem;
      font-weight: 500;
      color: var(--color-primary);
      text-decoration: none;
      display: block;
      margin-bottom: 0.3rem;
      line-height: 1.35;
    }

    .authority-list a:hover {
      color: var(--color-accent);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
    }

    .authority-citation {
      font-size: 0.86rem;
      color: var(--color-text-meta);
      font-family: var(--font-sans);
    }

    .index-summary {
      font-family: var(--font-serif);
      font-size: 1.15rem;
      line-height: 1.55;
      margin-bottom: 2.5rem;
      color: var(--color-text);
    }
  </style>

  <h1>Authority Index</h1>

  <p class="index-summary">
    {totalCount} regulatory authorities currently published. Pages grouped by
    authority type and listed with their formal citation. Each authority page
    contains verbatim text where available, plain-language summary, applicability
    scope, documentation evidence required, surveyor behavior, source confidence
    rating, and explicit notes on any adjacent claims that have been investigated
    and disconfirmed.
  </p>

  {typeOrder.map(type => grouped[type] && (
    <section>
      <h2>{typeLabels[type]}</h2>
      <ul class="authority-list">
        {grouped[type]
          .sort((a, b) => a.data.title.localeCompare(b.data.title))
          .map(authority => (
            <li>
              <a href={`/authorities/${authority.slug}/`}>{authority.data.title}</a>
              <span class="authority-citation">{authority.data.citation}</span>
            </li>
          ))}
      </ul>
    </section>
  ))}
</BaseLayout>
