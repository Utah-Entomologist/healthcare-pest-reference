---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  authority: CollectionEntry<'authorities'>;
}

const { authority } = Astro.props;
const {
  title,
  authority_type,
  citation,
  last_verified,
  source_url,
  source_tier,
  source_confidence,
  paywalled,
  verbatim_available
} = authority.data;

const description = `${title}. Source: ${citation}. Last verified ${last_verified.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}.`;

const authorityTypeLabels: Record<string, string> = {
  'federal regulator': 'Federal Regulator',
  'state regulator': 'State Regulator',
  'accrediting body': 'Accrediting Body',
  'recognized authority': 'Recognized Authority'
};
---

<BaseLayout
  title={title}
  description={description}
  authorityType={authority_type}
  citation={citation}
  lastVerified={last_verified}
>
  <h1>{title}</h1>

  <section class="authority-meta">
    <div class="authority-meta-header">Source Record</div>
    <dl>
      <dt>Authority Type</dt>
      <dd>{authorityTypeLabels[authority_type] || authority_type}</dd>

      <dt>Citation</dt>
      <dd>{citation}</dd>

      <dt>Primary Source</dt>
      <dd><a href={source_url} target="_blank" rel="noopener">{source_url}</a></dd>

      <dt>Source Tier</dt>
      <dd>Tier {source_tier}</dd>

      <dt>Confidence</dt>
      <dd class={source_confidence === 'HIGH' ? 'confidence-high' : 'confidence-medium'}>
        {source_confidence}
      </dd>

      <dt>Paywalled</dt>
      <dd>{paywalled ? 'Yes — institutional access recommended for litigation-grade use' : 'No'}</dd>

      <dt>Verbatim Available</dt>
      <dd>{verbatim_available ? 'Yes' : 'No — predecessor or paraphrase only'}</dd>

      <dt>Last Verified</dt>
      <dd>{last_verified.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</dd>
    </dl>

    <div class="verification-badge">
      <span>Verified by <strong>Trenton L. Frazer, BCE #B3413</strong> · Board Certified Entomologist · <a href="/methodology/">verification methodology</a></span>
    </div>
  </section>

  <slot />
</BaseLayout>
