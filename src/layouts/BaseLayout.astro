---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  authorityType?: string;
  citation?: string;
  lastVerified?: Date;
}

const {
  title,
  description,
  canonical,
  authorityType,
  citation,
  lastVerified
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const siteName = 'Healthcare Pest Reference';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={canonicalURL} />

  <title>{title} | {siteName}</title>
  <meta name="description" content={description} />

  <meta property="og:type" content="article" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content={siteName} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  {authorityType && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "url": canonicalURL,
      "publisher": {
        "@type": "Organization",
        "name": siteName,
        "url": "https://healthcarepestreference.org"
      },
      "author": {
        "@type": "Person",
        "name": "Trenton L. Frazer, BCE",
        "jobTitle": "Board Certified Entomologist (BCE #B3413)"
      },
      "citation": citation,
      "dateModified": lastVerified ? lastVerified.toISOString() : undefined
    })} />
  )}

  <style>
    :root {
      --color-bg: #ffffff;
      --color-text: #1a202c;
      --color-text-muted: #4a5568;
      --color-link: #2b6cb0;
      --color-link-hover: #2c5282;
      --color-border: #e2e8f0;
      --color-bg-subtle: #f7fafc;
      --color-warning: #c53030;
      --color-confidence-high: #2f855a;
      --color-confidence-medium: #b7791f;
      --max-width: 760px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      font-size: 16px;
      scroll-behavior: smooth;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Helvetica, Arial, sans-serif;
      color: var(--color-text);
      background: var(--color-bg);
      line-height: 1.6;
    }

    .site-header {
      border-bottom: 1px solid var(--color-border);
      padding: 1.5rem 1rem;
      background: var(--color-bg);
    }

    .site-header-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .site-title {
      font-size: 1.25rem;
      font-weight: 600;
      text-decoration: none;
      color: var(--color-text);
    }

    .site-nav {
      display: flex;
      gap: 1.5rem;
      font-size: 0.95rem;
    }

    .site-nav a {
      color: var(--color-text-muted);
      text-decoration: none;
    }

    .site-nav a:hover {
      color: var(--color-link);
    }

    main {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 2.5rem 1rem 4rem;
    }

    main h1 {
      font-size: 2.25rem;
      line-height: 1.2;
      margin-bottom: 1.5rem;
      letter-spacing: -0.02em;
    }

    main h2 {
      font-size: 1.5rem;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--color-border);
    }

    main h3 {
      font-size: 1.2rem;
      margin-top: 1.75rem;
      margin-bottom: 0.75rem;
    }

    main p {
      margin-bottom: 1rem;
    }

    main ul, main ol {
      margin: 0 0 1rem 1.5rem;
    }

    main li {
      margin-bottom: 0.5rem;
    }

    main blockquote {
      border-left: 4px solid var(--color-link);
      background: var(--color-bg-subtle);
      padding: 1rem 1.25rem;
      margin: 1.25rem 0;
      font-size: 0.95rem;
    }

    main blockquote p {
      margin-bottom: 0.75rem;
    }

    main blockquote p:last-child {
      margin-bottom: 0;
    }

    main a {
      color: var(--color-link);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 2px;
    }

    main a:hover {
      color: var(--color-link-hover);
    }

    main code {
      background: var(--color-bg-subtle);
      padding: 0.15em 0.35em;
      border-radius: 3px;
      font-size: 0.9em;
      font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
    }

    .authority-meta {
      background: var(--color-bg-subtle);
      border: 1px solid var(--color-border);
      border-radius: 6px;
      padding: 1.25rem;
      margin-bottom: 2rem;
      font-size: 0.9rem;
    }

    .authority-meta dl {
      display: grid;
      grid-template-columns: max-content 1fr;
      gap: 0.4rem 1rem;
    }

    .authority-meta dt {
      font-weight: 600;
      color: var(--color-text-muted);
    }

    .authority-meta dd {
      color: var(--color-text);
    }

    .confidence-high { color: var(--color-confidence-high); font-weight: 600; }
    .confidence-medium { color: var(--color-confidence-medium); font-weight: 600; }

    .site-footer {
      border-top: 1px solid var(--color-border);
      padding: 2rem 1rem;
      font-size: 0.85rem;
      color: var(--color-text-muted);
      background: var(--color-bg-subtle);
    }

    .site-footer-inner {
      max-width: var(--max-width);
      margin: 0 auto;
    }

    .site-footer p {
      margin-bottom: 0.75rem;
    }

    .site-footer a {
      color: var(--color-link);
    }

    @media (max-width: 600px) {
      main {
        padding: 1.5rem 1rem 3rem;
      }
      main h1 {
        font-size: 1.75rem;
      }
      .authority-meta dl {
        grid-template-columns: 1fr;
        gap: 0.2rem;
      }
      .authority-meta dt {
        margin-top: 0.5rem;
      }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-title">Healthcare Pest Reference</a>
      <nav class="site-nav">
        <a href="/authorities/">Authorities</a>
        <a href="/about/">About</a>
        <a href="/methodology/">Methodology</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="site-footer-inner">
      <p>
        Healthcare Pest Reference is an authoritative reference for healthcare pest control
        compliance, anchored in primary-source federal and state regulation, accrediting body
        standards, and recognized authority publications. Maintained by Trenton L. Frazer,
        BCE #B3413 (Board Certified Entomologist, General Entomology specialty).
      </p>
      <p>
        Content is intended as a reference resource for hospital risk management, infection
        prevention, plant operations, and procurement professionals. It is not legal advice.
        For litigation-grade applications, verify each citation against the primary source.
      </p>
      <p>© 2026 Healthcare Pest Reference. <a href="/about/">About</a> · <a href="/methodology/">Methodology</a></p>
    </div>
  </footer>
</body>
</html>
