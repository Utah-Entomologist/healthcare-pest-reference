---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  authorityType?: string;
  citation?: string;
  lastVerified?: Date;
}

const {
  title,
  description,
  canonical,
  authorityType,
  citation,
  lastVerified
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const siteName = 'Healthcare Pest Reference';
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={canonicalURL} />

  <title>{title} | {siteName}</title>
  <meta name="description" content={description} />

  <meta property="og:type" content="article" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content={siteName} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  {authorityType && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "url": canonicalURL,
      "publisher": {
        "@type": "Organization",
        "name": siteName,
        "url": "https://healthcarepestreference.org"
      },
      "author": {
        "@type": "Person",
        "name": "Trenton L. Frazer, BCE",
        "jobTitle": "Board Certified Entomologist (BCE #B3413)"
      },
      "citation": citation,
      "dateModified": lastVerified ? lastVerified.toISOString() : undefined
    })} />
  )}

  <style>
    :root {
      /* Deep healthcare green palette - clinical credibility */
      --color-primary: #1a3d2e;          /* deepest green, headings & primary brand */
      --color-primary-light: #2d5a44;    /* slightly lighter for hover */
      --color-accent: #4a7c5f;           /* medium green for links */
      --color-accent-hover: #335642;     /* link hover */
      --color-rule: #d4d8d2;             /* subtle rule lines */
      --color-rule-strong: #1a3d2e;      /* strong rules for hierarchy */

      /* Text */
      --color-text: #1c1f1d;             /* near-black with green undertone */
      --color-text-muted: #5a635e;       /* secondary text */
      --color-text-meta: #7a8580;        /* metadata, captions */

      /* Surface */
      --color-bg: #fdfdfb;               /* warm white, paper-feel */
      --color-bg-subtle: #f4f5f1;        /* metadata boxes, quotes */
      --color-bg-emphasis: #eef0eb;      /* slightly stronger emphasis */

      /* Confidence indicators */
      --color-confidence-high: #2d5a44;
      --color-confidence-medium: #8a6d1f;
      --color-warning: #a3331f;

      /* Typography */
      --font-serif: 'IBM Plex Serif', Georgia, 'Times New Roman', serif;
      --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;

      /* Layout */
      --max-width-prose: 720px;
      --max-width-wide: 980px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      font-size: 17px;
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      font-family: var(--font-sans);
      color: var(--color-text);
      background: var(--color-bg);
      line-height: 1.65;
      font-weight: 400;
    }

    /* Site header */
    .site-header {
      border-bottom: 1px solid var(--color-rule);
      background: var(--color-bg);
      padding: 1.5rem 1.5rem;
    }

    .site-header-inner {
      max-width: var(--max-width-wide);
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .site-brand {
      text-decoration: none;
      color: var(--color-primary);
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }

    .site-brand-mark {
      font-family: var(--font-serif);
      font-size: 1.35rem;
      font-weight: 600;
      letter-spacing: -0.015em;
      line-height: 1.1;
    }

    .site-brand-tagline {
      font-family: var(--font-sans);
      font-size: 0.72rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-text-meta);
    }

    .site-nav {
      display: flex;
      gap: 2rem;
      font-size: 0.92rem;
      font-weight: 500;
    }

    .site-nav a {
      color: var(--color-text-muted);
      text-decoration: none;
      padding: 0.25rem 0;
      border-bottom: 2px solid transparent;
      transition: color 0.15s ease, border-color 0.15s ease;
    }

    .site-nav a:hover {
      color: var(--color-primary);
    }

    .site-nav a.active {
      color: var(--color-primary);
      border-bottom-color: var(--color-primary);
    }

    /* Main content */
    main {
      max-width: var(--max-width-prose);
      margin: 0 auto;
      padding: 3rem 1.5rem 5rem;
    }

    main h1 {
      font-family: var(--font-serif);
      font-size: 2.5rem;
      font-weight: 600;
      line-height: 1.15;
      letter-spacing: -0.02em;
      color: var(--color-primary);
      margin-bottom: 1.75rem;
    }

    main h2 {
      font-family: var(--font-serif);
      font-size: 1.55rem;
      font-weight: 600;
      line-height: 1.25;
      letter-spacing: -0.01em;
      color: var(--color-primary);
      margin-top: 3rem;
      margin-bottom: 1.1rem;
      padding-bottom: 0.6rem;
      border-bottom: 1px solid var(--color-rule);
    }

    main h3 {
      font-family: var(--font-sans);
      font-size: 1.1rem;
      font-weight: 600;
      line-height: 1.3;
      color: var(--color-primary);
      margin-top: 2rem;
      margin-bottom: 0.75rem;
    }

    main p {
      margin-bottom: 1.15rem;
      color: var(--color-text);
    }

    main ul, main ol {
      margin: 0 0 1.25rem 1.5rem;
    }

    main li {
      margin-bottom: 0.6rem;
      line-height: 1.6;
    }

    main li::marker {
      color: var(--color-accent);
    }

    main blockquote {
      font-family: var(--font-serif);
      font-size: 0.98rem;
      font-style: normal;
      border-left: 3px solid var(--color-primary);
      background: var(--color-bg-subtle);
      padding: 1.1rem 1.4rem 1.1rem 1.5rem;
      margin: 1.5rem 0;
      color: var(--color-text);
      line-height: 1.6;
    }

    main blockquote p {
      margin-bottom: 0.85rem;
    }

    main blockquote p:last-child {
      margin-bottom: 0;
    }

    main a {
      color: var(--color-accent);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
      transition: color 0.15s ease;
    }

    main a:hover {
      color: var(--color-accent-hover);
    }

    main strong {
      font-weight: 600;
      color: var(--color-primary);
    }

    main code {
      background: var(--color-bg-subtle);
      padding: 0.12em 0.4em;
      border-radius: 3px;
      font-size: 0.88em;
      font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
      color: var(--color-primary);
    }

    /* Authority metadata box */
    .authority-meta {
      background: var(--color-bg-subtle);
      border: 1px solid var(--color-rule);
      border-left: 4px solid var(--color-primary);
      border-radius: 2px;
      padding: 1.4rem 1.5rem;
      margin-bottom: 2.5rem;
      font-size: 0.88rem;
      font-family: var(--font-sans);
    }

    .authority-meta-header {
      font-family: var(--font-sans);
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-text-meta);
      margin-bottom: 0.85rem;
      padding-bottom: 0.65rem;
      border-bottom: 1px solid var(--color-rule);
    }

    .authority-meta dl {
      display: grid;
      grid-template-columns: max-content 1fr;
      gap: 0.55rem 1.25rem;
      align-items: baseline;
    }

    .authority-meta dt {
      font-weight: 500;
      color: var(--color-text-muted);
      font-size: 0.83rem;
    }

    .authority-meta dd {
      color: var(--color-text);
      word-break: break-word;
    }

    .authority-meta a {
      color: var(--color-accent);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 2px;
      word-break: break-all;
    }

    .confidence-high {
      color: var(--color-confidence-high);
      font-weight: 600;
    }

    .confidence-medium {
      color: var(--color-confidence-medium);
      font-weight: 600;
    }

    /* Verification badge */
    .verification-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--color-bg-emphasis);
      border: 1px solid var(--color-rule);
      border-radius: 3px;
      padding: 0.5rem 0.85rem;
      font-size: 0.78rem;
      color: var(--color-text-muted);
      margin-top: 1rem;
    }

    .verification-badge strong {
      color: var(--color-primary);
      font-weight: 600;
    }

    .verification-badge a {
      color: var(--color-accent);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 2px;
    }

    /* Site footer */
    .site-footer {
      border-top: 1px solid var(--color-rule);
      padding: 2.5rem 1.5rem 3rem;
      background: var(--color-bg-subtle);
    }

    .site-footer-inner {
      max-width: var(--max-width-wide);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 3rem;
      font-size: 0.86rem;
      color: var(--color-text-muted);
      line-height: 1.6;
    }

    .site-footer-about p {
      margin-bottom: 0.85rem;
    }

    .site-footer-credentials {
      font-size: 0.82rem;
    }

    .site-footer-credentials h4 {
      font-family: var(--font-sans);
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-primary);
      margin-bottom: 0.75rem;
    }

    .site-footer-credentials ul {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .site-footer-credentials li {
      margin-bottom: 0.5rem;
    }

    .site-footer-credentials a {
      color: var(--color-accent);
      text-decoration: none;
    }

    .site-footer-credentials a:hover {
      text-decoration: underline;
    }

    .site-footer-bottom {
      max-width: var(--max-width-wide);
      margin: 2rem auto 0;
      padding-top: 1.5rem;
      border-top: 1px solid var(--color-rule);
      font-size: 0.78rem;
      color: var(--color-text-meta);
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .site-footer-bottom a {
      color: var(--color-text-muted);
      text-decoration: none;
    }

    .site-footer-bottom a:hover {
      color: var(--color-accent);
      text-decoration: underline;
    }

    /* Mobile */
    @media (max-width: 720px) {
      html {
        font-size: 16px;
      }

      main {
        padding: 2rem 1.25rem 3.5rem;
      }

      main h1 {
        font-size: 2rem;
      }

      main h2 {
        font-size: 1.35rem;
        margin-top: 2.25rem;
      }

      .site-header {
        padding: 1.25rem;
      }

      .site-header-inner {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
      }

      .site-nav {
        gap: 1.25rem;
      }

      .authority-meta {
        padding: 1.1rem 1.2rem;
      }

      .authority-meta dl {
        grid-template-columns: 1fr;
        gap: 0.25rem;
      }

      .authority-meta dt {
        margin-top: 0.65rem;
        font-size: 0.78rem;
      }

      .authority-meta dt:first-child {
        margin-top: 0;
      }

      .site-footer-inner {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .site-footer-bottom {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-brand">
        <span class="site-brand-mark">Healthcare Pest Reference</span>
        <span class="site-brand-tagline">A National Authoritative Reference</span>
      </a>
      <nav class="site-nav">
        <a href="/authorities/" class={currentPath.startsWith('/authorities') ? 'active' : ''}>Authorities</a>
        <a href="/methodology/" class={currentPath === '/methodology/' ? 'active' : ''}>Methodology</a>
        <a href="/about/" class={currentPath === '/about/' ? 'active' : ''}>About</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="site-footer-inner">
      <div class="site-footer-about">
        <p>
          Healthcare Pest Reference is an independent authoritative reference work
          mapping U.S. federal, state, and accrediting body pest control compliance
          requirements for healthcare facilities. Every requirement on this site is
          anchored to a primary source. Every commonly-circulated claim that has been
          investigated and disconfirmed is explicitly catalogued.
        </p>
        <p>
          Content serves hospital risk management, infection prevention, plant
          operations, procurement, and legal counsel. Citations should be verified
          against the primary source for any litigation-grade application. This
          reference is not legal advice.
        </p>
      </div>
      <div class="site-footer-credentials">
        <h4>Operator</h4>
        <ul>
          <li>Trenton L. Frazer, BCE</li>
          <li>Board Certified Entomologist</li>
          <li>BCE #B3413 · General Entomology</li>
          <li><a href="https://entocert.org/roster" target="_blank" rel="noopener">Verify credentials</a></li>
        </ul>
      </div>
    </div>
    <div class="site-footer-bottom">
      <span>© 2026 Healthcare Pest Reference</span>
      <span>
        <a href="/about/">About</a> · <a href="/methodology/">Methodology</a>
      </span>
    </div>
  </footer>
</body>
</html>
